{
  "realm": "payment",
  "displayName": "Payment Agent",
  "enabled": true,
  "loginTheme": "meu-agente-pix",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,
  "sslRequired": "none",
  "defaultSignatureAlgorithm": "RS256",

  "clients": [
    {
      "clientId": "payment-frontend",
      "name": "Payment Frontend",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:3000/*","https://localhost:3443/*","http://192.168.15.50:3000/*","https://192.168.15.50:3443/*"],
      "webOrigins": ["+"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access", "microprofile-jwt"]
    },
    {
      "clientId": "payment-agent",
      "name": "Payment Agent Backend",
      "enabled": true,
      "publicClient": false,
      "secret": "payment-agent-secret",
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect"
    }
  ],

  "roles": {
    "realm": [
      { "name": "USER", "description": "Standard bank customer" },
      { "name": "ADMIN", "description": "Bank administrator" }
    ]
  },

  "defaultRoles": ["USER"],

  "users": [
    {
      "username": "testuser",
      "email": "testuser@payment.com",
      "firstName": "Test",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "testpass123", "temporary": false }],
      "realmRoles": ["USER"]
    }
  ]
}
