# Stage 1: Build (Vite reads .env.production automatically in production mode)
FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# Stage 2: Serve with Nginx
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.prod.conf /etc/nginx/conf.d/default.conf
# TLS certs are mounted from the host (/etc/letsencrypt) at runtime — not baked in
EXPOSE 80 443
